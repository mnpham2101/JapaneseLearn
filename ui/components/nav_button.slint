import { CommonButton } from "common_button.slint";

export component NavButton inherits CommonButton {
    in property<string> button-text: "";

    // Use common button behavior while exposing nav-specific properties.
    text: button-text;
    border-radius: 4px;
    accessibilityLabel: button-text;

    // Keep the button text centered and accessible by default.
    accessible-description: button-text;
}
