import { CommonButton } from "common_button.slint";

export component CommonList {
    in property<string> title: "";
    in property<[string]> items: ["Item 1", "Item 2"];
    in property<string> addButtonText: "Add";
    callback addClicked;

    Rectangle {
        width: 100%;
        background: #ffffff;
        border-radius: 12px;
        border-width: 1px;
        border-color: #dfe6ee;

        VerticalLayout {
            padding: 16px;
            spacing: 12px;
            alignment: LayoutAlignment.stretch; 
            Text {
                text: title;
                font-size: 18px;
                color: #2c3e50;
                font-weight: 700;
            }


                @children
            

            CommonButton {
                width: 140px;
                text: addButtonText;
                primary: false;
                clicked => addClicked();
            }
        }
    }
}
