import { CommonButton } from "common_button.slint";

export component CommonList {
    in property<string> title: "";
    in property<[string]> items: ["Item 1", "Item 2"];
    in property<string> addButtonText: "Add";
    callback addClicked;

    Rectangle {
        width: 100%;
        background: #ffffff;
        border-radius: 12px;
        border-width: 1px;
        border-color: #dfe6ee;

        VerticalLayout {
            padding: 16px;
            spacing: 12px;

            Text {
                text: title;
                font-size: 18px;
                color: #2c3e50;
                font-weight: 700;
            }

            VerticalLayout {
                spacing: 10px;
                for item in items: Rectangle {
                    width: 100%;
                    height: 50px;
                    border-radius: 10px;
                    background: #f7f9fb;
                    border-width: 1px;
                    border-color: #d0d8e6;

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        alignment: center;

                        Text {
                            text: item;
                            font-size: 14px;
                            color: #34495e;
                        }
                    }
                }
            }

            CommonButton {
                width: 140px;
                text: addButtonText;
                primary: false;
                clicked => addClicked();
            }
        }
    }
}
