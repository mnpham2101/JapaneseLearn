import { Tokens } from "@styles";
import { NavBtn } from "components/nav_button.slint";
import { StudyPage } from "pages/study_page.slint";
import { ReviewPage } from "pages/review_page.slint";

// Page enum to track current page
enum PageType {
    StudyMode,
    ReviewMode,
}

import { FlashcardAppLogic } from "@flashcard";
import { VocabularyAppLogic } from "@vocabulary";

export component MainWindow inherits Window {
    width: 800px;
    height: 600px;
    title: "Japanese Learn";

    property <PageType> current-page: PageType.StudyMode;

    VerticalLayout {
        spacing: 0;

        Rectangle {
            background: Tokens.nav-background;
            height: 60px;

            HorizontalLayout {
                padding: 15px;
                alignment: start;
                spacing: 20px;

                Text {
                    text: "Japanese Learn";
                    font-size: Tokens.font-size-nav-title;
                    color: Tokens.text-on-dark;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle {
            background: Tokens.page-background;
            height: 480px;

            if current-page == PageType.StudyMode: StudyPage { }

            if current-page == PageType.ReviewMode: ReviewPage { }
        }

        Rectangle {
            background: Tokens.nav-bar-background;
            height: 60px;

            HorizontalLayout {
                padding: 10px;
                spacing: 10px;
                alignment: center;

                NavBtn {
                    width: 150px;
                    height: 40px;
                    button-text: "Study Mode";
                    primary: current-page == PageType.StudyMode;
                    clicked => {
                        current-page = PageType.StudyMode;
                    }
                }

                NavBtn {
                    width: 150px;
                    height: 40px;
                    button-text: "Review Mode";
                    primary: current-page == PageType.ReviewMode;
                    clicked => {
                        current-page = PageType.ReviewMode;
                    }
                }
            }
        }
    }
}
