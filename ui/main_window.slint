export component MainWindow inherits Window {
    width: 800px;
    height: 600px;
    title: "Japanese Learn";

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: #ffffff;

        Text {
            text: "Japanese Learn — Flashcards";
            horizontal-alignment: center;
            vertical-alignment: center;
            font-size: 24px;
            color: #333333;
        }
    }
}
