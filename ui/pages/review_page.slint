export component ReviewPage {
    width: 100%;
    height: 100%;

    Rectangle {
        width: 100%;
        height: 100%;
        background: #ffffff;

        VerticalLayout {
            padding: 20px;
            spacing: 20px;

            Text {
                text: "Review Mode";
                font-size: 28px;
                color: #333333;
            }

            Rectangle {
                background: #f5f5f5;
                border-radius: 8px;
                height: 300px;

                VerticalLayout {
                    alignment: center;
                    padding: 40px;

                    Text {
                        text: "Review your flashcard stacks and their progress";
                        horizontal-alignment: center;
                        font-size: 16px;
                        color: #666666;
                    }
                }
            }

            Rectangle {
                height: 60px;
                background: transparent;
            }
        }
    }
}
