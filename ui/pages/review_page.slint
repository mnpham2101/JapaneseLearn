import { Tokens } from "@styles";
import { CommonBtn } from "@common_component";
import { FlashcardAppLogic } from "@flashcard";
import { MatchingExerciseView } from "@vocabulary";

export component ReviewPage {
    width: 100%;
    height: 100%;

    // Local state — which stack is selected for review (-1 = none).
    property <int> selected-review-index: -1;
    // Whether the matching exercise is currently visible.
    property <bool> show-exercise: false;

    Rectangle {
        width: 100%;
        height: 100%;
        background: Tokens.page-background;

        VerticalLayout {
            padding: Tokens.padding-lg;
            spacing: Tokens.spacing-md;

            // Page heading
            Text {
                text: show-exercise
                    ? FlashcardAppLogic.flashcard-list[selected-review-index].stackname
                    : "Review Mode";
                font-size: Tokens.font-size-heading;
                color: Tokens.text-primary;
                horizontal-alignment: center;
            }

            // Stack selection list — shown when no exercise is active
            if !show-exercise: VerticalLayout {
                spacing: Tokens.spacing-sm;

                Text {
                    text: "Select a stack to practice:";
                    font-size: Tokens.font-size-caption;
                    color: Tokens.text-secondary;
                    horizontal-alignment: center;
                }

                for stack[i] in FlashcardAppLogic.flashcard-list: CommonBtn {
                    text: stack.stackname;
                    checkable: false;
                    clicked => {
                        selected-review-index = i;
                        show-exercise = true;
                    }
                }
            }

            // Matching exercise — shown when a stack is selected
            if show-exercise: VerticalLayout {
                spacing: Tokens.spacing-sm;

                CommonBtn {
                    width: 120px;
                    text: "Back";
                    clicked => {
                        show-exercise = false;
                        selected-review-index = -1;
                    }
                }

                MatchingExerciseView {
                    cards: FlashcardAppLogic.flashcard-list[selected-review-index].flashcards;
                    exercise-completed => {
                        show-exercise = false;
                        selected-review-index = -1;
                    }
                }
            }
        }
    }
}
