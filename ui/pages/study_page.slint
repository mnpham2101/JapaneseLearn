import { Tokens } from "@styles";
import { CommonBtn } from "@flashcard";
import { VocabularyPage } from "@vocabulary";

export component StudyPage {
    width: 100%;
    height: 100%;
    property <int> active-topic: 0;

    Rectangle {
        width: 100%;
        height: 100%;
        background: Tokens.page-background;

        VerticalLayout {
            spacing: 0;

            // ── Topic tab row ────────────────────────────────────────────────
            Rectangle {
                height: 44px;
                background: Tokens.topic-tab-bar-bg;

                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    spacing: 8px;
                    alignment: start;

                    CommonBtn {
                        width: 110px;
                        text: "Vocabulary";
                        checkable: true;
                        checked: root.active-topic == 0;
                        clicked => { root.active-topic = 0; }
                    }

                    CommonBtn {
                        width: 110px;
                        text: "Grammar";
                        checkable: true;
                        checked: root.active-topic == 1;
                        clicked => { root.active-topic = 1; }
                    }

                    CommonBtn {
                        width: 110px;
                        text: "Reading";
                        checkable: true;
                        checked: root.active-topic == 2;
                        clicked => { root.active-topic = 2; }
                    }
                }
            }

            // ── Tab content area ──────────────────────────────────────────────
            if root.active-topic == 0: VocabularyPage {
                width: 100%;
                vertical-stretch: 1;
            }

            if root.active-topic == 1: Rectangle {
                width: 100%;
                vertical-stretch: 1;
                background: Tokens.page-background;

                Text {
                    text: "Grammar — coming soon";
                    color: Tokens.text-secondary;
                    font-size: Tokens.font-size-body;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            if root.active-topic == 2: Rectangle {
                width: 100%;
                vertical-stretch: 1;
                background: Tokens.page-background;

                Text {
                    text: "Reading — coming soon";
                    color: Tokens.text-secondary;
                    font-size: Tokens.font-size-body;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}
