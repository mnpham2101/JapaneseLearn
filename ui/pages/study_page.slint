import { CommonList } from "../components/common_list.slint";
import { CommonButton } from "../components/common_button.slint";

export component StudyPage {
    width: 100%;
    height: 100%;
    property<[string]> items: ["Hiragana Basics", "N5 Vocabulary", "Travel Phrases"];
    Rectangle {
        width: 100%;
        height: 100%;
        background: #ffffff;

        VerticalLayout {
            padding: 20px;
            spacing: 20px;

            HorizontalLayout {
                spacing: 10px;
                alignment: center;

                Text {
                    text: "Study Mode";
                    font-size: 28px;
                    color: #333333;
                }

                CommonButton {
                    width: 140px;
                    text: "Create Stack";
                    primary: true;
                    clicked => {
                        // Placeholder action for create stack
                    }
                }
            }

            CommonList {
                title: "Flashcard Stacks";
                for item in items: Rectangle {
                    width: 100%;
                    height: 50px;
                    border-radius: 10px;
                    background: #f7f9fb;
                    border-width: 1px;
                    border-color: #d0d8e6;

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        alignment: center;

                        Text {
                            text: item;
                            font-size: 14px;
                            color: #34495e;
                        }
                    }
                }
                addButtonText: "Add Stack";
                addClicked => {
                    // Placeholder action for add stack
                }
            }
        }
    }
}