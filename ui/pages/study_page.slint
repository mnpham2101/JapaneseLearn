import { Tokens } from "@styles";
import { CommonBtn } from "@common_component";
import { VocabularyPage } from "@vocabulary";

export component StudyPage {
    width: 100%;
    height: 100%;
    property <int> active-topic: 0;

    Rectangle {
        width: 100%;
        height: 100%;
        background: Tokens.page-background;

        VerticalLayout {
            spacing: 0;

            // ── Topic tab row ────────────────────────────────────────────────
            Rectangle {
                height: Tokens.tab-bar-height;
                background: Tokens.topic-tab-bar-bg;
                VerticalLayout {
                    padding: Tokens.bar-padding-vertical;
                    HorizontalLayout {
                        padding-left: Tokens.bar-padding-horizontal;
                        padding-right: Tokens.bar-padding-horizontal;
                        spacing: Tokens.spacing-sm;
                        alignment: start;

                        CommonBtn {
                            width: 110px;
                            text: "Vocabulary";
                            checked: root.active-topic == 0;
                            clicked => {
                                root.active-topic = 0;
                            }
                        }

                        CommonBtn {
                            width: 110px;
                            text: "Grammar";
                            checked: root.active-topic == 1;
                            clicked => {
                                root.active-topic = 1;
                            }
                        }

                        CommonBtn {
                            width: 110px;
                            text: "Reading";
                            checked: root.active-topic == 2;
                            clicked => {
                                root.active-topic = 2;
                            }
                        }
                    }
                }
            }

            // ── Tab content area ──────────────────────────────────────────────
            if root.active-topic == 0: VocabularyPage {
                width: 100%;
                vertical-stretch: 1;
            }

            if root.active-topic == 1: Rectangle {
                width: 100%;
                vertical-stretch: 1;
                background: Tokens.page-background;

                Text {
                    text: "Grammar — coming soon";
                    color: Tokens.text-secondary;
                    font-size: Tokens.font-size-body;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            if root.active-topic == 2: Rectangle {
                width: 100%;
                vertical-stretch: 1;
                background: Tokens.page-background;

                Text {
                    text: "Reading — coming soon";
                    color: Tokens.text-secondary;
                    font-size: Tokens.font-size-body;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}
