import { Tokens } from "@styles";
import { CommonBtn } from "common_button.slint";
import { FlashcardModel, FlashcardStackModel } from "../model/flashcard_model.slint";

export { FlashcardModel, FlashcardStackModel }

export component Flashcard {
    in property<FlashcardModel> data: { jap-obj: "", explanation: "", known: true };
    in-out property<bool> show-back: false;
    in-out property<bool> known: data.known;

    callback flipped;

    min-width: 200px;

    Rectangle {
        width: 100%;
        height: 180px;
        background: known ? Tokens.known-bg : Tokens.unknown-bg;
        border-radius: 16px;
        border-width: 2px;
        border-color: known ? Tokens.known-border : Tokens.unknown-border;

        // Full-card touch for flip — lower z-order than known button
        TouchArea {
            clicked => {
                show-back = !show-back;
                flipped();
            }
        }

        VerticalLayout {
            alignment: center;
            padding: 20px;
            spacing: 6px;

            if !show-back: Text {
                text: data.jap-obj;
                font-size: Tokens.font-size-large;
                color: Tokens.text-primary;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            if show-back: Text {
                text: data.jap-obj;
                font-size: Tokens.font-size-body;
                color: Tokens.text-secondary;
                horizontal-alignment: center;
            }

            if show-back: Text {
                text: data.explanation;
                font-size: Tokens.font-size-explanation;
                color: Tokens.text-primary;
                horizontal-alignment: center;
                vertical-alignment: center;
                wrap: word-wrap;
            }

            Text {
                text: show-back ? "Tap to hide" : "Tap to reveal";
                font-size: Tokens.font-size-small;
                color: Tokens.unknown-icon-color;
                horizontal-alignment: center;
            }
        }

        // Known toggle — top-right corner, higher z-order captures its own clicks.
        // checkable + two-way binding replaces the clicked callback entirely.
        CommonBtn {
            checkable: true;
            checked <=> known;
            x: parent.width - self.width - 8px;
            y: 8px;
            width: 32px;
            height: 32px;
            text: known ? "✓" : "✗";
            accessibilityLabel: known ? "Mark as unknown" : "Mark as known";
        }
    }
}
