import { CommonBtn } from "common_button.slint";
import { FlashcardStackModel } from "../model/flashcard_model.slint";

// A clickable label representing one flashcard stack.
// Inherits CommonBtn so it shares all visual states (checked, primary, enabled).
// The `checked` property is set externally by the parent (one-way binding) to reflect
// whether this stack is currently selected — no checkable toggle needed here.
export component FlashcardLabel inherits CommonBtn {
    in property<FlashcardStackModel> stack: { stackname: "", flashcards: [] };
    text: stack.stackname;
    // Cap width so the label fits within its container instead of overlapping the border
    // (CommonBtn defaults to width: 100%, which overflows unconstrained centering layouts).
    max-width: 320px;
}
