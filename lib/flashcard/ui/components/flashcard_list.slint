import { CommonList } from "common_list.slint";
import { FlashcardLabel } from "flashcard_label.slint";
import { FlashcardStackModel } from "../model/flashcard_model.slint";

// List of flashcard stacks shown as selectable labels.
// selected-index tracks which label is active; -1 means none selected.
export component FlashcardList {
    in property <[FlashcardStackModel]> stacks;
    in-out property <int> selected-index: -1;

    HorizontalLayout {
        alignment: LayoutAlignment.center;
        VerticalLayout {
            spacing: 10px;
            alignment: LayoutAlignment.center;
            for stack[i] in stacks: FlashcardLabel {
                stack: stack;
                // Mutually exclusive selection logic: only one label can be checked at a time.
                checked: root.selected-index == i;
                clicked => {
                    root.selected-index = i;
                }
            }
        }
    }
}
