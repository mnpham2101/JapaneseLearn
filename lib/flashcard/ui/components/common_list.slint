import { CommonBtn } from "common_button.slint";

export component CommonList {
    in property<string> title: "";
    in property<[string]> items: ["Item 1", "Item 2"];
    in property<string> addButtonText: "Add";
    // Toggled by the add button; bind <=> to the parent's form-visible property
    // so clicking the button opens/closes the create form declaratively.
    in-out property <bool> add-stack: false;

    Rectangle {
        width: 100%;
        background: #ffffff;
        border-radius: 12px;
        border-width: 1px;
        border-color: #dfe6ee;

        VerticalLayout {
            padding: 16px;
            spacing: 12px;
            alignment: LayoutAlignment.stretch;
            Text {
                text: title;
                font-size: 18px;
                color: #2c3e50;
                font-weight: 700;
            }

            @children

            CommonBtn {
                width: 140px;
                text: addButtonText;
                primary: true;
                checkable: true;
                checked <=> add-stack;
            }
        }
    }
}
