import { FlashcardStackModel } from "model/flashcard_model.slint";

export global FlashcardAppLogic {
    in-out property <[FlashcardStackModel]> flashcard-list: [
        {
            stackname: "Hiragana Basics",
            flashcards: [
                { jap-obj: "あ", explanation: "a", known: false },
                { jap-obj: "い", explanation: "i", known: false },
                { jap-obj: "う", explanation: "u", known: false },
            ],
        },
        {
            stackname: "N5 Vocabulary",
            flashcards: [
                { jap-obj: "水", explanation: "water (mizu)", known: false },
                { jap-obj: "火", explanation: "fire (hi)", known: false },
            ],
        },
        {
            stackname: "Travel Phrases",
            flashcards: [
                { jap-obj: "ありがとう", explanation: "Thank you", known: false },
                { jap-obj: "すみません", explanation: "Excuse me", known: false },
            ],
        },
    ];
    in-out property <int> selected-stack-index: -1;

    // Phase 8.V — sentence flashcards (generated from vocabulary example sentences,
    // persisted separately to sentences.json). Decoupled from flashcard-list/
    // selected-stack-index above; never written to by the manual CRUD callbacks.
    in-out property <[FlashcardStackModel]> sentence-stack-list: [];
    in-out property <int> selected-sentence-stack-index: -1;

    // Phase 4 study session state
    in-out property <bool> study-session-active: false;
    // in-out (not in) — the Slint compiler constant-folds a global "in" property
    // that no .slint binding ever writes to (only Rust does, via the generated
    // setter, which the compiler's binding-constancy analysis can't see),
    // baking its literal default into every dependent expression instead of a
    // live reactive binding. in-out properties are never folded this way.
    in-out property <int> known-count: 0;
    in-out property <int> total-count: 0;
    callback known-changed(stack-index: int, card-index: int, known: bool);
    // Fired when a study session opens — known-changed only fires on a toggle,
    // so without this, known-count/total-count keep whatever value the *previous*
    // session left them at (or 0) until the user touches the known button.
    callback study-session-opened();

    // Phase 2 callbacks — wired from UI to Rust handlers in lib/flashcard/src/lib.rs::init()
    callback stack-create-confirmed(name: string);
    callback stack-delete-confirmed();
    callback flashcard-add-confirmed(jap: string, meaning: string);
    callback flashcard-field-changed(card-index: int, jap: string, meaning: string);
    callback flashcard-delete-confirmed(card-index: int);
    callback flashcard-reordered(from-index: int, to-index: int);

    // Phase 5 — persistent data import/export (wired by persistent_data::init())
    callback import-stack-clicked();
    callback export-stack-clicked();
}
