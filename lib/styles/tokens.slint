// Design tokens — single source of truth for all shared visual constants.
// Import this file (via @styles) wherever hardcoded colors, sizes, or radii would otherwise appear.
export global Tokens {
    // ── Border ───────────────────────────────────────────────────────────────
    out property <color> border-color: #b0c4de;
    out property <length> border-width: 1px;
    out property <length> border-radius: 6px;

    // ── Card field background ─────────────────────────────────────────────────
    out property <color> card-field-background: #ffffff;

    // ── Card container ────────────────────────────────────────────────────────
    out property <color> card-container-background: #f0f4f8;
    out property <length> card-container-border-radius: 12px;
    out property <color> card-container-border-color: #c8d6e5;

    // ── Text colors ───────────────────────────────────────────────────────────
    out property <color> text-primary: #2c3e50;
    out property <color> text-secondary: #7f8c8d;
    out property <color> text-placeholder: #aaaaaa;
    out property <color> text-on-dark: #ffffff;

    // ── Spacing ───────────────────────────────────────────────────────────────
    out property <length> padding-lg: 16px;
    out property <length> padding-sm: 8px;
    out property <length> spacing-md: 12px;
    out property <length> spacing-sm: 8px;
    out property <length> spacing-xs: 6px;

    // ── Font sizes ────────────────────────────────────────────────────────────
    out property <length> font-size-title: 20px;
    out property <length> font-size-body: 18px;
    out property <length> font-size-caption: 16px;
    out property <length> font-size-heading: 28px;
    out property <length> font-size-large: 36px;
    out property <length> font-size-small: 12px;

    // ── Button state colors ───────────────────────────────────────────────────
    // Default (normal) state
    out property <color> btn-default-bg: #ecf0f1;
    out property <color> btn-default-text: #2c3e50;
    out property <color> btn-default-border: #bdc3c7;

    // Hover state
    out property <color> btn-hover-bg: #d5dbdb;
    out property <color> btn-hover-text: #2c3e50;

    // Pressed state
    out property <color> btn-pressed-bg: #b2babb;
    out property <color> btn-pressed-text: #2c3e50;

    // Disabled state
    out property <color> btn-disabled-bg: #f2f3f4;
    out property <color> btn-disabled-text: #b2babb;

    // Primary button (filled)
    out property <color> btn-primary-bg: #2980b9;
    out property <color> btn-primary-text: #ffffff;
    out property <color> btn-primary-hover-bg: #2471a3;
    out property <color> btn-primary-pressed-bg: #1f618d;

    // ── Known / unknown indicator colors ──────────────────────────────────────
    out property <color> known-bg: #eafaf1;
    out property <color> known-border: #27ae60;
    out property <color> known-icon-color: #27ae60;
    out property <color> unknown-bg: #f7f9fb;
    out property <color> unknown-border: #d0d8e6;
    out property <color> unknown-icon-color: #95a5a6;

    // ── Page / nav backgrounds ────────────────────────────────────────────────
    out property <color> page-background: #ffffff;
    out property <color> nav-background: #2c3e50;
    out property <color> nav-bar-background: #ecf0f1;

    // ── Input field colors ────────────────────────────────────────────────────
    out property <color> input-background: #ffffff;
    out property <color> input-border: #b0c4de;
    out property <color> input-text: #2c3e50;
    out property <color> input-form-background: #f5f5f5;

    // ── Stack label colors ────────────────────────────────────────────────────
    out property <color> stack-label-bg: #eaf2fb;
    out property <color> stack-label-border: #aed6f1;
    out property <color> stack-label-text: #1a5276;

    // ── Drop-target highlight ─────────────────────────────────────────────────
    out property <color> drag-target-highlight: #dce8f5;
}
