// Design tokens — single source of truth for all shared visual constants.
// Import this file (via @styles) wherever hardcoded colors, sizes, or radii would otherwise appear.
export global Tokens {
    // ── Border ───────────────────────────────────────────────────────────────
    out property <color> border-color: #D4A373;
    out property <length> border-width: 1px;
    out property <length> border-radius: 6px;

    // ── Card field background ─────────────────────────────────────────────────
    out property <color> card-field-background: #FEFAE0;

    // ── Card container ────────────────────────────────────────────────────────
    out property <color> card-container-background: #FAEDCD;
    out property <length> card-container-border-radius: 12px;
    out property <color> card-container-border-color: #D4A373;

    // ── Text colors ───────────────────────────────────────────────────────────
    out property <color> text-primary: #251504;
    out property <color> text-secondary: #D4A373;
    out property <color> text-placeholder: #160303;
    out property <color> text-on-dark: #FEFAE0;

    // ── Spacing ───────────────────────────────────────────────────────────────
    out property <length> padding-lg: 16px;
    out property <length> padding-sm: 8px;
    out property <length> spacing-md: 12px;
    out property <length> spacing-sm: 8px;
    out property <length> spacing-xs: 6px;

    // ── Font sizes ────────────────────────────────────────────────────────────
    out property <length> font-size-title: 20px;
    out property <length> font-size-body: 18px;
    out property <length> font-size-caption: 16px;
    out property <length> font-size-heading: 28px;
    out property <length> font-size-large: 36px;
    out property <length> font-size-small: 12px;
    // Input / button label text (compact controls)
    out property <length> font-size-input: 14px;
    // App nav title
    out property <length> font-size-nav-title: 24px;
    // Explanation text on card back
    out property <length> font-size-explanation: 26px;
    // Extra-large font for kanji front face — brush-stroke calligraphic rendering.
    out property <length> font-size-kanji: 72px;

    // ── Button state colors ───────────────────────────────────────────────────
    // Default (normal) state
    out property <color> btn-default-bg: #E9EDC9;
    out property <color> btn-default-text: #251504;
    out property <color> btn-default-border: #CCD5AE;

    // Hover state
    out property <color> btn-hover-bg: #CCD5AE;
    out property <color> btn-hover-text: #251504;

    // Pressed state
    out property <color> btn-pressed-bg: #D4A373;
    out property <color> btn-pressed-text: #251504;

    // Disabled state
    out property <color> btn-disabled-bg: #f2f3f4;
    out property <color> btn-disabled-text: #b2babb;

    // Primary button (filled)
    out property <color> btn-primary-bg: #D4A373;
    out property <color> btn-primary-text: #FEFAE0;
    out property <color> btn-primary-hover-bg: #C08040;
    out property <color> btn-primary-pressed-bg: #A06820;

    // ── Known / unknown indicator colors ──────────────────────────────────────
    out property <color> known-bg: #E9EDC9;
    out property <color> known-border: #CCD5AE;
    out property <color> known-icon-color: #251504;
    out property <color> unknown-bg: #FAEDCD;
    out property <color> unknown-border: #D4A373;
    out property <color> unknown-icon-color: #95a5a6;

    // ── Page / nav backgrounds ────────────────────────────────────────────────
    out property <color> page-background: #FEFAE0;
    out property <color> nav-background: #251504;
    out property <color> nav-bar-background: #D4A373;

    // ── Input field colors ────────────────────────────────────────────────────
    out property <color> input-background: #FEFAE0;
    out property <color> input-border: #D4A373;
    out property <color> input-text: #251504;
    out property <color> input-form-background: #FAEDCD;

    // ── Stack label colors ────────────────────────────────────────────────────
    out property <color> stack-label-bg: #FAEDCD;
    out property <color> stack-label-border: #D4A373;
    out property <color> stack-label-text: #251504;

    // ── Drop-target highlight ─────────────────────────────────────────────────
    out property <color> drag-target-highlight: #CCD5AE;

    // ── Bar-level distinction ─────────────────────────────────────────────────
    // StudyPage topic tab row (top-level navigation: Vocabulary / Grammar / Reading)
    out property <color> topic-tab-bar-bg: #D4A373;
    // VocabularyPage action bar (secondary navigation: Lesson / Exercise / Flashcard)
    out property <color> action-bar-bg: #CCD5AE;
    // Active button color for VocabularyPage action bar tabs (distinct from topic-tab active = nav-background)
    out property <color> action-tab-btn-active-bg: #D4A373;
}
