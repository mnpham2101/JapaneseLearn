import { CommonBtn } from "@flashcard";
import { VocabularyAppLogic } from "../vocabulary_app_logic.slint";
import { Tokens } from "@styles";
import { Tokens } from "../../../styles/themes/theme_solarized_light.slint";

component TextBox inherits Rectangle {
    in property <string> text;
    border-color: Tokens.border-color;
    border-radius: Tokens.border-radius;
    border-width: 1px;
    Text {
        text: root.text;
        font-size: Tokens.font-size-body;
        color: Tokens.text-primary;
        vertical-alignment: center;
        horizontal-alignment: center;
    }
}


// Detail pane for the currently selected vocabulary lesson.
// Shows the word list with delete buttons and an inline WordForm for adding new words.
// Uses the Vertically stacked up components pattern — alignment end, form slides up from bottom.
export component LessonDetailPane inherits Rectangle {
    border-color: Tokens.border-color;
    border-radius: Tokens.border-radius;
    border-width: Tokens.border-width;
    preferred-width: 100%;

    VerticalLayout {
        spacing: Tokens.spacing-sm;
        padding: Tokens.padding-sm;

        // Word rows — one per word in the selected lesson.
        for word[i] in VocabularyAppLogic.lesson-list[VocabularyAppLogic.selected-lesson-index].words: Rectangle {
            height: 44px;
            border-radius: Tokens.border-radius;

            HorizontalLayout {
                spacing: Tokens.padding-sm;
                padding: Tokens.padding-sm;

                // Spelling
                TextBox {
                    text: word.spelling;
                    horizontal-stretch: 3;
                }

                TextBox {
                    text: word.kanji;
                    horizontal-stretch: 3;
                }

                TextBox {
                    text: word.meaning;
                    horizontal-stretch: 3;
                }

                TextBox {
                    text: word.word-type;
                    horizontal-stretch: 3;
                }

                // Delete button for this word row.
                Rectangle {
                    CommonBtn {
                        width: 50px;
                        height: 36px;
                        text: "Close";
                        accessibilityLabel: "Delete word " + word.spelling;
                        clicked => {
                            VocabularyAppLogic.word-delete-confirmed(
                            VocabularyAppLogic.selected-lesson-index,
                            i);
                        }
                    }
                }
            }
        }
    }
}
