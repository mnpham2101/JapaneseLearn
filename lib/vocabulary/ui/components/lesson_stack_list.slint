import { CommonBtn } from "@flashcard";
import { LessonStackLabel } from "lesson_stack_label.slint";
import { VocabularyAppLogic } from "../vocabulary_app_logic.slint";
import { Tokens } from "@styles";

// Scrollable list of vocabulary lessons rendered as LessonStackLabel rows,
// with an inline create-lesson form and an "＋ Add Lesson" button at the bottom.
export component LessonStackList inherits VerticalLayout {
    // State for the create-lesson inline form.
    property <bool> show-create-form: false;

    // Scrollable lesson rows.
    Flickable {
        vertical-stretch: 1;
        viewport-height: lesson-rows.preferred-height;

        lesson-rows := VerticalLayout {
            spacing: Tokens.spacing-sm;
            padding: Tokens.padding-sm;

            for lesson[i] in VocabularyAppLogic.lesson-list: HorizontalLayout {
                spacing: Tokens.spacing-sm;

                // Lesson label — checkable, mirrors FlashcardLabel usage.
                LessonStackLabel {
                    horizontal-stretch: 1;
                    height: 36px;
                    lesson: lesson;
                    checkable: true;
                    checked: VocabularyAppLogic.selected-lesson-index == i;
                    clicked => {
                        VocabularyAppLogic.selected-lesson-index = i;
                    }
                }

                // Delete button for this lesson row.
                CommonBtn {
                    width: 36px;
                    height: 36px;
                    text: "✕";
                    accessibilityLabel: "Delete lesson " + lesson.name;
                    clicked => {
                        VocabularyAppLogic.selected-lesson-index = i;
                        VocabularyAppLogic.lesson-delete-confirmed();
                    }
                }
            }
        }
    }

    // Create-lesson form — slides up from the bottom when show-create-form is true.
    if root.show-create-form: Rectangle {
        background: Tokens.input-form-background;
        border-radius: Tokens.border-radius;
        height: self.visible ? 64px : 0px;

        HorizontalLayout {
            padding: Tokens.padding-sm;
            spacing: Tokens.spacing-sm;
            alignment: center;

            // Lesson name input field.
            name-field := Rectangle {
                horizontal-stretch: 1;
                height: 36px;
                border-width: Tokens.border-width;
                border-color: Tokens.border-color;
                border-radius: Tokens.border-radius;
                background: Tokens.card-field-background;

                name-input := TextInput {
                    font-size: Tokens.font-size-body;
                    color: Tokens.text-primary;
                    vertical-alignment: center;
                    width: parent.width - 12px;
                    x: Tokens.spacing-xs;
                }

                Text {
                    visible: name-input.text == "";
                    text: "Lesson name...";
                    font-size: Tokens.font-size-body;
                    color: Tokens.text-placeholder;
                    vertical-alignment: center;
                    x: Tokens.spacing-xs;
                }
            }

            CommonBtn {
                width: 90px;
                height: 36px;
                text: "Confirm";
                primary: true;
                accessibilityLabel: "Confirm add lesson";
                clicked => {
                    VocabularyAppLogic.lesson-create-confirmed(name-input.text);
                    name-input.text = "";
                    root.show-create-form = false;
                }
            }

            CommonBtn {
                width: 80px;
                height: 36px;
                text: "Cancel";
                accessibilityLabel: "Cancel add lesson";
                clicked => {
                    name-input.text = "";
                    root.show-create-form = false;
                }
            }
        }
    }

    // "＋ Add Lesson" button — hidden while the form is open.
    if !root.show-create-form: HorizontalLayout {
        alignment: center;
        CommonBtn {
            width: min(parent.width, 200px);
            height: 36px;
            text: "＋ Add Lesson";
            primary: true;
            accessibilityLabel: "Open add lesson form";
            clicked => {
                root.show-create-form = true;
            }
        }
    }
}
