import { Tokens } from "@styles";
import { CommonBtn } from "@flashcard";
import { VocabularyAppLogic } from "../vocabulary_app_logic.slint";
import { LessonStackList } from "../components/lesson_stack_list.slint";
import { LessonDetailView } from "../components/lesson_detail_view.slint";
import { FlashcardManagerView } from "../components/flashcard_manager_view.slint";

// Top-level vocabulary page with a three-tab action bar (Lesson/Exercise/Flashcard)
// and an Import Lesson direct-action button.
// View 0 — Lesson: LessonStackList or LessonDetailView (vertically stacked pattern).
// View 1 — Exercise: Generate Flashcards and Export Vocabulary buttons.
// View 2 — Flashcard: FlashcardManagerView.
export component VocabularyPage inherits Rectangle {
    background: Tokens.page-background;

    VerticalLayout {
        spacing: 0;

        // ── Notification banner — shown when a generation message is pending ──
        if VocabularyAppLogic.generation-notification != "": Rectangle {
            height: 36px;
            background: Tokens.btn-primary-bg;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 8px;

                Text {
                    text: VocabularyAppLogic.generation-notification;
                    color: Tokens.text-on-dark;
                    vertical-alignment: center;
                    horizontal-alignment: left;
                    horizontal-stretch: 1;
                }

                CommonBtn {
                    width: 28px;
                    height: 28px;
                    text: "✕";
                    accessibilityLabel: "Dismiss notification";
                    clicked => { VocabularyAppLogic.generation-notification = ""; }
                }
            }
        }

        // ── Action bar (height: 44px) ────────────────────────────────────────
        Rectangle {
            height: 44px;
            background: Tokens.action-bar-bg;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 8px;
                alignment: start;

                CommonBtn {
                    width: 90px;
                    text: "Lesson";
                    checked: VocabularyAppLogic.active-view == 0;
                    checked-bg: Tokens.action-tab-btn-active-bg;
                    checked-text: Tokens.text-primary;
                    clicked => { VocabularyAppLogic.active-view = 0; }
                }

                CommonBtn {
                    width: 90px;
                    text: "Exercise";
                    checked: VocabularyAppLogic.active-view == 1;
                    checked-bg: Tokens.action-tab-btn-active-bg;
                    checked-text: Tokens.text-primary;
                    clicked => { VocabularyAppLogic.active-view = 1; }
                }

                CommonBtn {
                    width: 90px;
                    text: "Flashcard";
                    checked: VocabularyAppLogic.active-view == 2;
                    checked-bg: Tokens.action-tab-btn-active-bg;
                    checked-text: Tokens.text-primary;
                    clicked => { VocabularyAppLogic.active-view = 2; }
                }

                // Direct-action button — fires import and returns to current view.
                CommonBtn {
                    width: 120px;
                    text: "Import Lesson";
                    clicked => { VocabularyAppLogic.import-vocabulary-clicked(); }
                }
            }
        }

        // ── View 0: Lesson ────────────────────────────────────────────────────
        if VocabularyAppLogic.active-view == 0: Rectangle {
            vertical-stretch: 1;
            background: Tokens.page-background;

            if VocabularyAppLogic.selected-lesson-index >= 0: LessonDetailView {
                width: 100%;
                height: 100%;
                close-clicked => {
                    VocabularyAppLogic.selected-lesson-index = -1;
                }
            }

            if VocabularyAppLogic.selected-lesson-index < 0: VerticalLayout {
                width: 100%;
                height: 100%;
                spacing: 8px;
                padding: 8px;

                HorizontalLayout {
                    alignment: center;
                    spacing: Tokens.spacing-sm;

                    CommonBtn {
                        text: "Restore Defaults";
                        width: 160px;
                        clicked => { VocabularyAppLogic.restore-defaults-clicked(); }
                    }

                    CommonBtn {
                        text: "＋ Add Lesson";
                        width: 160px;
                        primary: true;
                        checkable: true;
                        checked <=> lesson-stack-list.show-create-form;
                        accessibilityLabel: "Open add lesson form";
                    }
                }

                HorizontalLayout {
                    alignment: center;
                    vertical-stretch: 1;
                    lesson-stack-list := LessonStackList {
                        width: min(parent.width - 16px, 480px);
                    }
                }
            }
        }

        // ── View 1: Exercise ──────────────────────────────────────────────────
        if VocabularyAppLogic.active-view == 1: Rectangle {
            vertical-stretch: 1;
            background: Tokens.page-background;

            HorizontalLayout {
                alignment: center;
                spacing: 12px;

                CommonBtn {
                    text: "Generate Flashcards";
                    primary: true;
                    clicked => { VocabularyAppLogic.generate-exercises-clicked(); }
                }

                CommonBtn {
                    text: "Export Vocabulary";
                    clicked => { VocabularyAppLogic.export-vocabulary-clicked(); }
                }
            }
        }

        // ── View 2: Flashcard ─────────────────────────────────────────────────
        if VocabularyAppLogic.active-view == 2: FlashcardManagerView {
            vertical-stretch: 1;
        }
    }
}
